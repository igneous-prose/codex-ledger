{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Aggregate Report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "generator_version",
    "filters",
    "timezone",
    "pricing",
    "data"
  ],
  "properties": {
    "schema_version": {
      "const": "phase4-aggregate-report-v1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "generator_version": {
      "type": "string"
    },
    "filters": {
      "type": "object",
      "required": [
        "period",
        "as_of"
      ],
      "properties": {
        "period": {
          "type": "string"
        },
        "as_of": {
          "type": "string"
        }
      }
    },
    "timezone": {
      "const": "UTC"
    },
    "pricing": {
      "type": "object",
      "required": [
        "included",
        "warnings",
        "coverage_status"
      ],
      "properties": {
        "included": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coverage_status": {
          "type": "string"
        }
      }
    },
    "data": {
      "type": "object",
      "required": [
        "period_buckets"
      ],
      "properties": {
        "period_buckets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "date",
              "total_tokens"
            ],
            "properties": {
              "date": {
                "type": "string"
              },
              "total_tokens": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  }
}
